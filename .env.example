# ─── Firebase ───────────────────────────────────────────────────────────────
# Firebase Console → Project settings → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Firebase (server-side) ──────────────────────────────────────────────────
# Same values as above but WITHOUT VITE_ prefix — used by api/chat.js to
# verify Firebase ID tokens. Set these in Vercel dashboard, not .env.local.
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Server-side only — never exposed to the browser (no VITE_ prefix)
# Used by api/chat.js for the AI assistant
# Generate at https://console.anthropic.com
ANTHROPIC_API_KEY=
