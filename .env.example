# Firebase — get from console.firebase.google.com → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AI — Google Gemini (free tier)
# Get from: https://aistudio.google.com/app/apikey
# Server-side only — set in Vercel dashboard, NOT prefixed with VITE_
GEMINI_API_KEY=your-gemini-key-here

# Same value as VITE_FIREBASE_API_KEY but without the VITE_ prefix (for server-side token verification)
FIREBASE_API_KEY=your-firebase-api-key-here

# Same value as VITE_FIREBASE_PROJECT_ID (for per-user daily AI call tracking)
FIREBASE_PROJECT_ID=your-project-id-here
