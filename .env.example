# ─── Firebase ───────────────────────────────────────────────────────────────
# Firebase Console → Project settings → Your apps → Web app → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Firebase (server-side) ──────────────────────────────────────────────────
# Same values as above but WITHOUT VITE_ prefix — used by api/chat.js to
# verify Firebase ID tokens. Set these in Vercel dashboard, not .env.local.
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=

# ─── Sentry (error monitoring, optional) ─────────────────────────────────────
# Create a free React project at https://sentry.io → copy the DSN.
# Leave empty to disable monitoring entirely (safe default).
VITE_SENTRY_DSN=

# ─── Google Gemini (AI assistant) ────────────────────────────────────────────
# Server-side only — never use a VITE_ prefix (that would bundle it into the
# client). Used by api/chat.js for the AI assistant.
# Generate at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
