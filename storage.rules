rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Event images — all authenticated users can read; only admins / class admins
    // can write. Storage rules can read Firestore via firestore.get(), so we gate
    // uploads on the user's role instead of leaving writes open to any user.
    match /events/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && (
                     firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin']
                     || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('classAdminFor', []).size() > 0
                   );
    }

    // Child profile photos — linked parent writes; readable only by a linked
    // parent, admins, or same-class parents/class-admins (mirrors Firestore)
    match /children/{childId}/{fileName} {
      allow read: if request.auth != null
                  && (
                    request.auth.uid in firestore.get(/databases/(default)/documents/children/$(childId)).data.get('parentUids', [])
                    || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
                         in ['admin', 'super_admin']
                    || firestore.get(/databases/(default)/documents/children/$(childId)).data.get('classId', '~')
                         in firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('classIds', [])
                    || firestore.get(/databases/(default)/documents/children/$(childId)).data.get('classId', '~')
                         in firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('classAdminFor', [])
                  );
      allow write: if request.auth != null
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && (
                     request.auth.uid in firestore.get(/databases/(default)/documents/children/$(childId)).data.get('parentUids', [])
                     || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
                          in ['admin', 'super_admin']
                   );
    }

    // User avatars — own user writes; authenticated reads
    match /users/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Class cover images — admin or class-admin writes; authenticated reads
    match /classes/{classId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && (
                     firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin']
                     || classId in firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('classAdminFor', [])
                   );
    }

    // Task form files (PDF or image) — admin / class-admin writes; authenticated reads
    match /tasks/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf')
                   && (
                     firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin']
                     || firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('classAdminFor', []).size() > 0
                   );
    }

    // Community images (announcements, resources) — admin writes; authenticated reads
    match /community/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
                        in ['admin', 'super_admin'];
    }

    // Feedback screenshots — file name is <feedbackId>.<ext>; the write is
    // allowed only for the owner of that feedback doc (created just before the
    // upload), so one user can't overwrite another's screenshot or dump blobs.
    // Only admins/super_admins can read.
    match /feedback/{fileName} {
      allow read: if request.auth != null
                  && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin'];
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && firestore.get(/databases/(default)/documents/feedback/$(fileName.split('\\.')[0]))
                        .data.submittedBy.uid == request.auth.uid;
    }

    // Business directory images — owner writes their own subfolder; authenticated reads
    match /businesses/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
