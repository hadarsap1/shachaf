rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Any authenticated user can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;

      // Admins and super_admins can read all profiles
      allow read: if request.auth != null
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                     in ['admin', 'super_admin'];

      // Same-class parents can read each other's profiles (for class roster)
      allow read: if request.auth != null
                  && resource.data.get('classIds', []).hasAny(
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classIds', [])
                     );

      // Host families can read new_family profiles (for their families view)
      allow read: if request.auth != null
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'host_family'
                  && resource.data.role == 'new_family';

      // Class admins are publicly readable — they are the community contact directory
      allow read: if request.auth != null
                  && resource.data.get('classAdminFor', []).size() > 0;

      // Class admins can read members of the classes they administer (to approve/manage them)
      allow read: if request.auth != null
                  && resource.data.get('classIds', []).hasAny(
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', [])
                     );

      // Users can create their own profile — but cannot self-assign privileged
      // roles, class-admin powers, or class membership. `imported` may only be
      // set when a matching pendingFamilies record exists (i.e. the family was
      // imported by an admin) — it gates access to the unlinked-children roster.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.get('role', 'community')
                       in ['community', 'new_family', 'host_family']
                    && request.resource.data.get('roles', [])
                       .hasOnly(['community', 'new_family', 'host_family'])
                    && request.resource.data.get('classAdminFor', []).size() == 0
                    && request.resource.data.get('classIds', []).size() == 0
                    && (request.resource.data.get('imported', false) == false
                        || exists(/databases/$(database)/documents/pendingFamilies/$(request.auth.token.email.lower())));

      // Users can update their own profile but cannot change role, classAdminFor,
      // or imported. classIds may only: stay equal, shrink (privacy-reducing is
      // always safe), or grow by exactly ONE class proven by a child doc the user
      // is a linked parent of (classProofChildId; getAfter so the child-link and
      // classIds update can share a batch).
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.get('roles', []) == resource.data.get('roles', [])
                    && request.resource.data.get('classAdminFor', []) == resource.data.get('classAdminFor', [])
                    && request.resource.data.get('imported', false) == resource.data.get('imported', false)
                    && (
                      request.resource.data.get('classIds', []) == resource.data.get('classIds', [])
                      || resource.data.get('classIds', []).hasAll(request.resource.data.get('classIds', []))
                      || (
                        request.resource.data.get('classIds', []).hasAll(resource.data.get('classIds', []))
                        && request.resource.data.get('classIds', []).removeAll(resource.data.get('classIds', [])).size() == 1
                        && request.auth.uid in getAfter(/databases/$(database)/documents/children/$(request.resource.data.get('classProofChildId', '-'))).data.get('parentUids', [])
                        && getAfter(/databases/$(database)/documents/children/$(request.resource.data.get('classProofChildId', '-'))).data.get('classId', '')
                             == request.resource.data.get('classIds', []).removeAll(resource.data.get('classIds', []))[0]
                      )
                    );

      // Admins and super_admins can update any user including changing roles
      // but only super_admins can assign the super_admin role
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin']
                    && (
                      request.resource.data.role != 'super_admin'
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
                    );

      // Class admins can approve/deny (change only the status field) members of their own classes
      allow update: if request.auth != null
                    && resource.data.get('classIds', []).hasAny(
                         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', [])
                       )
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // Tasks — admins read/write all; families read their assigned tasks
    match /tasks/{taskId} {
      allow read: if request.auth != null
                  && (resource.data.assignedTo == request.auth.uid
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                         in ['admin', 'super_admin']);
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                      in ['admin', 'super_admin'];
    }

    // Events — all authenticated users can read; admins write all;
    // class admins can create/update/delete events scoped to their own classes only
    match /events/{eventId} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                      in ['admin', 'super_admin'];

      allow create, update: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', []).size() > 0
                   && request.resource.data.get('classIds', []).size() > 0
                   && request.resource.data.get('classIds', []).hasOnly(
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', [])
                      );

      allow delete: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', []).size() > 0
                   && resource.data.get('classIds', []).size() > 0
                   && resource.data.get('classIds', []).hasOnly(
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', [])
                      );

      // Any authenticated user may RSVP (add/remove only their own uid from attendeeUids)
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendeeUids'])
                    && (
                         (request.resource.data.attendeeUids.hasAll(resource.data.attendeeUids)
                          && request.resource.data.attendeeUids.removeAll(resource.data.attendeeUids) == [request.auth.uid])
                         ||
                         (resource.data.attendeeUids.hasAll(request.resource.data.attendeeUids)
                          && resource.data.attendeeUids.removeAll(request.resource.data.attendeeUids) == [request.auth.uid])
                       );

      // Group members can create and delete events scoped to their group
      allow create: if request.auth != null
                    && request.resource.data.groupId is string
                    && request.resource.data.createdBy == request.auth.uid
                    && request.auth.uid in get(/databases/$(database)/documents/hobbyGroups/$(request.resource.data.groupId)).data.get('memberUids', []);
      allow delete: if request.auth != null
                    && resource.data.groupId is string
                    && resource.data.createdBy == request.auth.uid;
    }

    // Forms — published forms readable by all auth users; only admins write
    match /forms/{formId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                      in ['admin', 'super_admin'];
    }

    // Submissions — owner or co-parent can read/update; admins read all
    match /submissions/{subId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.uid in resource.data.get('coParentUids', [])
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.uid in resource.data.get('coParentUids', [])
      );
      allow read: if request.auth != null
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                     in ['admin', 'super_admin'];
    }

    // Messages (contact us) — any auth user can create; only admins can read/update
    match /messages/{msgId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.get('subject', '').size() <= 200
                    && request.resource.data.get('body', '').size() <= 5000;
      allow read, update: if request.auth != null
                          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                             in ['admin', 'super_admin'];
    }

    // AI usage counters — each user can only read/write their own.
    // Write rule prevents resetting the count: on the same date the count
    // may only increase (prevents a user from zeroing their counter to bypass
    // the daily limit). A new date resets to any value (server sets it to 1).
    match /aiUsage/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && (
                     !exists(/databases/$(database)/documents/aiUsage/$(uid))
                     || request.resource.data.date != resource.data.date
                     || request.resource.data.count >= resource.data.count
                   );
    }

    // Pending imported families — admins manage; each user can read/delete their own record
    match /pendingFamilies/{emailId} {
      allow read, delete: if request.auth != null
                          && emailId == request.auth.token.email;
      allow read, write, delete: if request.auth != null
                                 && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                                    in ['admin', 'super_admin'];
    }

    // Classes — all authenticated users can read; admins and class admins write
    match /classes/{classId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                          in ['admin', 'super_admin']
                      || classId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', []));
    }

    // Children — readable only by a linked parent, by admins, or by a parent/
    // class-admin of the SAME class (for the class roster). Not globally readable.
    // `classIds` on the user profile is maintained client-side (syncUserClassIds).
    // a linked parent can add another parent (update parentUids only)
    match /children/{childId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.get('parentUids', [])
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
             in ['admin', 'super_admin']
        || resource.data.get('classId', '')
             in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classIds', [])
        || resource.data.get('classId', '')
             in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', [])
        // Onboarding: only admin-imported families (imported flag, validated at
        // profile-create time against pendingFamilies) can browse unlinked
        // children to self-link. Random self-registered accounts cannot.
        || (resource.data.get('parentUids', []).size() == 0
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('imported', false) == true)
      );
      allow write: if request.auth != null
                   && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                          in ['admin', 'super_admin']
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('classAdminFor', []).size() > 0);
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.parentUids
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentUids', 'hobbies', 'pet', 'photoUrl', 'photoPath']);
      // Onboarding: an imported family can claim an unlinked child by setting parentUids to [themselves]
      allow update: if request.auth != null
                    && resource.data.get('parentUids', []).size() == 0
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('imported', false) == true
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentUids'])
                    && request.resource.data.parentUids == [request.auth.uid];
    }

    // Admin notes — admin-only read/write, invisible to families
    match /adminNotes/{childId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ['admin', 'super_admin'];
    }

    // Child notes — each parent can only read/write their own notes
    match /childNotes/{noteId} {
      allow read, delete: if request.auth != null
        && resource.data.parentId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.parentId == request.auth.uid
        && request.resource.data.get('content', '').size() <= 10000;
      allow update: if request.auth != null
        && resource.data.parentId == request.auth.uid
        && request.resource.data.get('content', '').size() <= 10000;
    }

    // Resources — all authenticated users can read; only admins write
    match /resources/{resourceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                      in ['admin', 'super_admin'];
    }

    // Committees — all authenticated users can read; admins write;
    // any authenticated user may add/remove only their own uid from memberUids
    match /committees/{committeeId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                               in ['admin', 'super_admin'];
      // Any auth user can request a new committee — created as 'pending', awaiting admin review
      allow create: if request.auth != null
                    && request.resource.data.status == 'pending'
                    && request.resource.data.requestedBy == request.auth.uid;
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin'];
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
                    && (
                         (request.resource.data.memberUids.hasAll(resource.data.memberUids)
                          && request.resource.data.memberUids.removeAll(resource.data.memberUids) == [request.auth.uid])
                         ||
                         (resource.data.memberUids.hasAll(request.resource.data.memberUids)
                          && resource.data.memberUids.removeAll(request.resource.data.memberUids) == [request.auth.uid])
                       );
    }

    // Committee chat — all authenticated can read; members can create (size-limited); admins delete
    match /committeeChat/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.get('text', '').size() <= 2000
                    && request.resource.data.committeeId is string
                    && request.auth.uid in get(/databases/$(database)/documents/committees/$(request.resource.data.committeeId)).data.get('memberUids', []);
      allow delete: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin'];
    }

    // Committee summaries — all authenticated can read; only admins write
    match /committeeSummaries/{summaryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                      in ['admin', 'super_admin'];
    }

    // Community group chat — all authenticated can read; members can create (size-limited); admins delete
    match /groupChat/{msgId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.get('text', '').size() <= 2000
                    && request.resource.data.groupId is string
                    && request.auth.uid in get(/databases/$(database)/documents/hobbyGroups/$(request.resource.data.groupId)).data.get('memberUids', []);
      allow delete: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin'];
    }

    // Group member-contributed links — members can create/delete own; admins delete any; all auth read
    match /groupLinks/{linkId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.get('url', '').matches('https?://.*')
                    && request.resource.data.get('url', '').size() <= 2000
                    && request.resource.data.get('label', '').size() <= 200
                    && request.resource.data.groupId is string
                    && request.auth.uid in get(/databases/$(database)/documents/hobbyGroups/$(request.resource.data.groupId)).data.get('memberUids', []);
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
    }

    // Group member-contributed files — members can create/delete own; admins delete any; all auth read
    match /groupFiles/{fileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.groupId is string
                    && request.auth.uid in get(/databases/$(database)/documents/hobbyGroups/$(request.resource.data.groupId)).data.get('memberUids', []);
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin']);
    }

    // Announcements — all authenticated users can read; only admins write
    match /announcements/{annId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                      in ['admin', 'super_admin'];
    }

    // Committee messages — any auth user can send; admins can read/update all;
    // sender can read their own messages
    match /committeeMessages/{msgId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.get('body', '').size() <= 2000;
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null
                          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                             in ['admin', 'super_admin'];
    }

    // Hobby/interest groups — all authenticated can read; admins manage; any user can join/leave
    match /hobbyGroups/{groupId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                               in ['admin', 'super_admin'];
      // Any auth user can request a new group — created as 'pending', awaiting admin review
      allow create: if request.auth != null
                    && request.resource.data.status == 'pending'
                    && request.resource.data.requestedBy == request.auth.uid;
      // Admin full update; any authenticated user may add/remove only their own uid from memberUids
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                       in ['admin', 'super_admin'];
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
                    && (
                         // join: only their own uid was appended
                         (request.resource.data.memberUids.hasAll(resource.data.memberUids)
                          && request.resource.data.memberUids.removeAll(resource.data.memberUids) == [request.auth.uid])
                         ||
                         // leave: only their own uid was removed
                         (resource.data.memberUids.hasAll(request.resource.data.memberUids)
                          && resource.data.memberUids.removeAll(request.resource.data.memberUids) == [request.auth.uid])
                       );
    }

    // Settings (e.g. emergencyMode) — all authenticated can read; only admins write
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                      in ['admin', 'super_admin'];
    }

    // Emergency daily schedule — all authenticated can read; only admins write
    match /emergencySchedule/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                      in ['admin', 'super_admin'];
    }

    // Feedback / bug reports — any auth user can submit their own; only admins/super_admins review
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
                    && request.resource.data.submittedBy.uid == request.auth.uid
                    && request.resource.data.get('text', '').size() <= 2000;
      // Submitter can attach a screenshot URL after upload (nothing else)
      allow update: if request.auth != null
                    && resource.data.submittedBy.uid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['screenshotUrl']);
      allow read, update: if request.auth != null
                          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                             in ['admin', 'super_admin'];
    }

    // Community businesses — all auth can read; owner creates/updates own; admin/owner delete
    match /communityBusinesses/{bizId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.get('businessName', '').size() <= 200
                    && request.resource.data.get('description', '').size() <= 2000;
      allow update: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                           in ['admin', 'super_admin'])
                    && request.resource.data.uid == resource.data.uid;
      allow delete: if request.auth != null
                    && (resource.data.uid == request.auth.uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
                           in ['admin', 'super_admin']);
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
